# Copy this file to .env and fill in your values. .env is gitignored.
#   cp .env.example .env   &&   $EDITOR .env

# Which model backend the app + harness use: mock | openai | hf
MODEL_BACKEND=openai

# --- OpenAI backend ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
# Flatten the conversation into one user message (1) to reproduce the paper's
# content-based role confusion, or map to native API roles (0).
OPENAI_FLATTEN=1

# --- Local open-model backend (MODEL_BACKEND=hf) ---
# HF_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# --- Local model-server route (eval.local_gpu) ---
# Serve a non-hardened open model with any OpenAI-compatible local server
# (KoboldCpp, llama.cpp, vLLM, LM Studio, Ollama, ...) and run the harness
# against it. See docs/LOCAL_GPU.md.
# COT_MODEL_GGUF=./models/your-model.gguf   # model to serve (default KoboldCpp cmd)
# KOBOLDCPP_EXE=koboldcpp.exe               # KoboldCpp binary (or on PATH)
# KOBOLD_URL=http://localhost:5001          # model server base URL
# KOBOLD_CMD=                               # full launch command (overrides the above)

# --- Optional GPU lease (if this machine runs a GPU-arbitration service) ---
# GPU_LEASE_URL=http://127.0.0.1:3000
# GPU_LEASE_NAME=cot-resistance
# GPU_LEASE_API_KEY=      # the arbiter's API key (omit / use --no-lease if none)
